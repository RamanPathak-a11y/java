//  Take a 4 digit number as a input from the user and WAP to perform the
// addition of their digits without using loop

import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();

        int d1 = n / 1000;
        int d2 = (n / 100) % 10;
        int d3 = (n / 10) % 10;
        int d4 = n % 10;

        int sum = d1 + d2 + d3 + d4;
        System.out.println(sum);
    }
}

//  Take a 4 digit number as a input from the user and WAP to perform the
// addition of first and last digits without using loop

import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();

        int first = n / 1000;
        int last = n % 10;

        int sum = first + last;
        System.out.println(sum);
    }
}
